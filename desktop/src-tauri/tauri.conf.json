{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TinyNote",
  "version": "1.2.3",
  "identifier": "com.tinynote.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TinyNote 小笺",
        "label": "main",
        "width": 360,
        "height": 620,
        "minWidth": 320,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxOTFGMDk2M0I3MzEzMDAKUldRQUUzTTdsdkNSUVJiRGtNRk81d0pjcHkwamo0blI0K01xL2o5T3RVdXJpVkdLSnBDbStZVmgK",
      "endpoints": [
        "https://github.com/se-treasurew/TinyNote/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "sql": {
      "preload": ["sqlite:tinynote.db"]
    }
  }
}
