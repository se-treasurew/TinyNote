{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TinyNote",
  "version": "0.1.5",
  "identifier": "com.tinynote.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TinyNote 小笺",
        "label": "main",
        "width": 360,
        "height": 620,
        "minWidth": 320,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:tinynote.db"]
    }
  }
}
